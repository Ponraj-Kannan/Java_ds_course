# ── Server-side only (Vercel serverless / Node backend) ──────────────────────
ZOHO_CLIENT_ID=1000.1CVBYZL4FQUMZPEM57U5TUZYR6D6SQ
ZOHO_CLIENT_SECRET=f4dd90404e05932131d213a0aacd94818071e5fb42

# ── Frontend (VITE_ prefix = bundled into the browser, public) ──────────────
